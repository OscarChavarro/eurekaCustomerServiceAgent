meta {
  name: Post Chat Completions (Wrapper)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/chat/completions
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "messages": [
      {
        "role": "user",
        "content": "venden botellas de vino?"
      }
    ],
    "hints": {
      "customerId": "555-1234567"
    },
    "max_tokens": 1000,
    "show_used_context": true
  }
}

vars:pre-request {
  baseUrl: http://localhost:3668
}
