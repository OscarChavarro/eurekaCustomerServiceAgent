#!/bin/sh
set -e

for backend in ingestionBackend backofficeBackend retrievalBackend contactsBackend preprocessorForIMazing; do
  echo "Running arch:check in ${backend}"
  (cd "$backend" && npm run arch:check)
done

for backend in ingestionBackend backofficeBackend retrievalBackend preprocessorForIMazing; do
  echo "Running lint in ${backend}"
  (cd "$backend" && npm run lint)
done
