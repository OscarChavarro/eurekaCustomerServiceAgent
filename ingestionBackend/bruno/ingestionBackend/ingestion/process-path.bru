meta {
  name: Process Path
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/ingestion/process-path
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "path": "{{folderPath}}"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3666
  folderPath: ./etc/_chatsEureka/csv
}
