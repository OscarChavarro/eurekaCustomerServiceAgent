meta {
  name: Get Profile Image
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/profileImage?phoneNumber={{phoneNumber}}&size=normal
  body: none
  auth: none
}

params:query {
  phoneNumber: {{phoneNumber}}
  size: normal
}

headers {
  Accept: image/*
}

vars:pre-request {
  baseUrl: http://localhost:3670
  phoneNumber: <define-phone-number-with-country-code>
}
