meta {
  name: Get Profile Image
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/profileImage?phoneNumber={{phoneNumber}}&size={{size}}&cached-only={{cachedOnly}}
  body: none
  auth: none
}

params:query {
  phoneNumber: {{phoneNumber}}
  size: {{size}}
  cached-only: {{cachedOnly}}
}

headers {
  Accept: image/*
}

vars:pre-request {
  baseUrl: http://localhost:3670
  phoneNumber: <define-phone-number-with-country-code>
  size: original
  cachedOnly: false
}
