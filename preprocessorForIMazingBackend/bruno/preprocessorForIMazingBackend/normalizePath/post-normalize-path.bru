meta {
  name: Normalize Path
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/normalizePath
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "path": "{{rootFolderPath}}"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3671
  rootFolderPath: ./etc/iMazing_exported_whatsapp_logs_csv_example
}
