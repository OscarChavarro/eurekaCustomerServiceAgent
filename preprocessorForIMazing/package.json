  },
  "keywords": [
    "typescript",
    "whatsapp",
    "rename",
    "preprocess"
  ],
  "author": "OpenAI",
  "license": "GPL",
  "devDependencies": {
    "@types/node": "20.17.57",
    "rimraf": "5.0.10",
    "tslint": "6.1.3",
    "typescript": "4.9.5"
  }
}
